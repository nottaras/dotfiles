#!/bin/bash

apps=(
  "Slack"
  "Microsoft Teams"
  "Microsoft Outlook"
  "Claude"
  "Google Chrome"
  "Obsidian" 
)

start() {
  for app in "${apps[@]}"; do
    if osascript -e "tell application \"$app\" to launch" 2>/dev/null; then
      echo "✅ $app"
    else
      echo "⚠️  $app — not found, skipping"
    fi
  done
}

stop() {
  for app in "${apps[@]}"; do
    if osascript -e "quit app \"$app\"" 2>/dev/null; then
      echo "✅ $app — closed"
    else
      echo "⚠️  $app — not running or not found"
    fi
  done
}

case "$1" in
  stop)   stop ;;
  start)  start ;;
  *)      start ;;  # default
esac

