# Fallback identity for repos outside ~/Projects/personal or ~/Projects/work
[user]
    name  = Taras Zadziarnouski
    email = taras.zadziarnouski@gmail.com

# Profile overrides — must come after [user] so they take precedence
[includeIf "gitdir:~/Projects/personal/"]
    path = ~/.gitconfig-personal

[includeIf "gitdir:~/Projects/work/"]
    path = ~/.gitconfig-work

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default          = current
    autoSetupRemote  = true

[rebase]
    autoStash = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[alias]
    st      = status -sb
    co      = checkout
    br      = branch -vv
    lg      = log --oneline --graph --decorate --all
    last    = log -1 HEAD --stat
    unstage = reset HEAD --
    undo    = reset --soft HEAD~1

[core]
	editor = nvim
